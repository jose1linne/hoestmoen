---
import Layout from "../layouts/Layout.astro";

const url = `${import.meta.env.SUPERBASE_URL}/rest/v1/artistTabel?select=*`;
const apiKey = import.meta.env.SUPABASE_PUBLISHABLE_KEY;

const options = {
  headers: {
    apikey: apiKey,
  },
};

const data = await fetch(url, options).then((res) => res.json());

console.log(data);
---

<Layout titel="Høsten">
  {data.map((student) => <Student student={student} />)}
</Layout>
